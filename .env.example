# .env.example
# Copy to .env and fill in the actual values.
# NEVER commit .env to version control.

# Flask
SECRET_KEY=<generate-a-strong-random-key>
FLASK_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://anniecushing@localhost:5432/auditmaton_ads

# Firebase Authentication (for client-side Google sign-in)
FIREBASE_API_KEY=<your-firebase-api-key>
FIREBASE_AUTH_DOMAIN=<your-project>.firebaseapp.com
FIREBASE_PROJECT_ID=<your-project-id>
GOOGLE_APPLICATION_CREDENTIALS=<path-to-service-account-json>

# Email (Flask-Mail via Gmail SMTP)
MAIL_USERNAME=<your-gmail-address>
MAIL_PASSWORD=<your-gmail-app-password>
MAIL_DEFAULT_SENDER=<your-gmail-address>

# Authorize.net (payment processing)
AUTHORIZE_NET_API_LOGIN_ID=<your-login-id>
AUTHORIZE_NET_TRANSACTION_KEY=<your-transaction-key>
AUTHORIZE_NET_PUBLIC_CLIENT_KEY=<your-public-client-key>
AUTHORIZE_NET_SANDBOX=true
